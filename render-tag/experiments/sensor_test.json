{
    "name": "sensor_verification",
    "base_config": {
        "dataset": {
            "num_scenes": 1,
            "output_dir": "output/sensor_v1"
        },
        "scene": {
            "lighting": {
                "intensity_min": 100,
                "intensity_max": 100
            }
        },
        "camera": {
            "samples_per_scene": 1,
            "min_distance": 2.0,
            "max_distance": 3.0,
            "velocity_mean": 2.0,
            "velocity_std": 0.0,
            "shutter_time_ms": 100.0,
            "fstop": 1.4,
            "focus_distance": 1.0,
            "iso_noise": 0.5
        }
    },
    "sweeps": [
        {
            "type": "linear",
            "parameter": "camera.shutter_time_ms",
            "min": 0.0,
            "max": 50.0,
            "steps": 2
        }
    ]
}
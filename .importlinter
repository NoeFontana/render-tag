[importlinter]
root_package = render_tag
include_external_packages = True

[importlinter:contract:host-isolation]
name = Host isolation (Orchestration & Core)
type = forbidden
source_modules =
    render_tag.orchestration
    render_tag.core
forbidden_modules =
    bpy
    render_tag.backend

[importlinter:contract:determinism-enforcement]
name = Determinism enforcement (Generation)
type = forbidden
source_modules =
    render_tag.generation
forbidden_modules =
    random
